(* MLB for the sml-font library: the vendored sml-raster core (which itself
 * pulls in sml-image + sml-inflate + sml-color) plus the font sources.
 * Consumers reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so consumers can
 * `open Image`/`Raster` alongside Font. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-raster/sources.mlb
font.sig
font.sml
